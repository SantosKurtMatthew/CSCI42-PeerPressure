generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PomodoroInteraction {
  id            Int       @default(autoincrement()) @id
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  focusTime     Int       @default(25)
  restTime      Int       @default(5)
  userId        String?   // Added relation to user
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  // New fields from Data Dictionary
  loginStreak   Int       @default(0)

  // Relations
  tasks         Task[]    @relation("TaskAssignee")
  interactions  TaskInteraction[]
  meetingsCreated MeetingSchedule[] @relation("MeetingOrganizer")
  meetingAvails MeetingAvailability[]
  pomodoros     PomodoroInteraction[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// =========================================
// NEW MODELS ADDED FROM DELIVERABLE 3 DATA DICTIONARY
// =========================================

model Category {
  id            Int     @id @default(autoincrement())
  categoryName  String  @default("No Category")
  tasks         Task[]
}

model Task {
  id              Int       @id @default(autoincrement())
  taskName        String    @default("To Do")
  taskDescription String?
  status          String    @default("Backlog") // "Backlog", "In Progress", "For Review", "Done"
  softDeadline    DateTime?
  hardDeadline    DateTime  @default(dbgenerated("NOW() + interval '1 week'"))
  repetition      Int       @default(1) // 0: no repeat, 1: daily, 7: weekly
  
  // Relations
  categoryId      Int?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  assignedToId    String?
  assignedTo      User?     @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Subtasks
  parentId        Int?
  parentTask      Task?     @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks        Task[]    @relation("Subtasks")

  // Dependencies (Self Relation)
  dependencyId    Int?
  dependsOn       Task?     @relation("Dependencies", fields: [dependencyId], references: [id], onDelete: SetNull)
  dependentTasks  Task[]    @relation("Dependencies")

  meetings        MeetingSchedule[]
  interactions    TaskInteraction[]
}

model TaskInteraction {
  id              Int       @id @default(autoincrement())
  timestamp       DateTime  @default(now())
  interactionType String    @default("Create") // Create, Edit, Complete
  
  taskId          Int
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeetingSchedule {
  id                  Int       @id @default(autoincrement())
  meetingName         String    @default("Meeting")
  meetingDescription  String?
  startDate           DateTime  @default(now())    @db.Date
  endDate             DateTime                     @db.Date
  startTime           String    @default("09:00:00") // Time only
  endTime             String    @default("17:00:00") // Time only
  
  taskId              Int?
  task                Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  startedById         String
  startedBy           User      @relation("MeetingOrganizer", fields: [startedById], references: [id], onDelete: Cascade)

  availabilities      MeetingAvailability[]
}

model MeetingAvailability {
  id                  Int       @id @default(autoincrement())
  scheduleId          Int
  schedule            MeetingSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date                DateTime  @db.Date
  timeSlot            String    // Represented as 'HH:mm' for 30-min intervals
  status              String    @default("Free") // "Free" or "Busy"

  @@unique([scheduleId, userId, date, timeSlot])
}